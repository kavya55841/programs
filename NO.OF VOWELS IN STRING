class vowel
{
    public static void main(String args[])
    {
        int count=0;
        String s="abedjfnikbdojkbdundoae";
        for(int i=0;i<s.length();i++)
        {
            if(s.charAt(i)=='a'||s.charAt(i)=='e'||s.charAt(i)=='i'||s.charAt(i)=='o'||s.charAt(i)=='u')
            {
                count++;
                char c=s.charAt(i);
                System.out.print(c);

            }
        }
        System.out.println(count);
    }
}
